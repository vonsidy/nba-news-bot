# Copy this file to .env and fill in your keys.

# Claude API key — https://platform.claude.com
ANTHROPIC_API_KEY=

# X (Twitter) API credentials — https://developer.x.com
# Your app needs "Read and write" permissions (User authentication settings).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# true = print tweets to console instead of posting (safe testing mode)
DRY_RUN=true

# Seconds between feed checks. 60-120 is a good balance of speed vs politeness.
POLL_SECONDS=90

# Hard cap so a busy news day can't burn through the X free tier
# (free tier allows ~500 posts/month, so ~15/day is the safe ceiling).
MAX_POSTS_PER_DAY=15
